{
  "identifier": "settings",
  "description": "Settings window (dialog picker, autostart toggle, invoke commands)",
  "windows": ["settings"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:event:default",
    "core:event:allow-listen",
    "dialog:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled"
  ]
}
